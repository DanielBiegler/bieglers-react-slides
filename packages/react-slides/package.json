{
  "name": "@danielbiegler/react-slides",
  "version": "0.1.0",
  "description": "Framework for building beautiful, portable, local presentations in TSX",
  "keywords": ["react", "presentations", "slides", "typescript", "vite"],
  "author": "Daniel Biegler",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielBiegler/bieglers-react-slides.git"
  },
  "homepage": "https://danielbiegler.github.io/bieglers-react-slides/",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/index.css",
    "./vite-plugin": {
      "import": "./dist/vite-plugin.js",
      "types": "./dist/vite-plugin.d.ts"
    }
  },
  "sideEffects": ["dist/index.css"],
  "files": ["dist", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist && cp src/styles/fonts/LICENSE-*.txt dist/",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "latest",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "typescript": "^5.0.0",
    "vite": "8.0.16"
  },
  "dependencies": {
    "prism-react-renderer": "2.4.1"
  }
}
